{% extends 'base.html.twig' %}

{% block body %}
    <h1>Mes commandes</h1>

    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Valide</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for commande in commandes %}
            <tr>
                <td>{{ commande.date ? commande.date|date('d/m/Y H:i') : '–' }}</td>
                <td>{{ commande.valide ? '✅' : '❌' }}</td>
                <td>
                    <a href="{{ path('app_commande_show', {'id': commande.id}) }}">Voir</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucune commande</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
