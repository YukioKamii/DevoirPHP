{% extends 'base.html.twig' %}

{% block title %}Détails de la commande{% endblock %}

{% block body %}
    <h1>Détails de la commande</h1>

    <ul>
        <li><strong>Date :</strong> {{ commande.date ? commande.date|date('d/m/Y H:i') : '–' }}</li>
        <li><strong>Utilisateur :</strong> {{ commande.user.email }}</li>
        <li><strong>Valide :</strong> {{ commande.valide ? '✅ Oui' : '❌ Non' }}</li>
    </ul>

    <h2>Lunettes associées :</h2>
    {% if commande.lunettes|length > 0 %}
        <ul>
            {% for lunette in commande.lunettes %}
                <li>
                    Série : {{ lunette.serie }} —
                    Quantité : {{ lunette.quantite }} —
                    Catégorie : {{ lunette.categorie.nom }}
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Aucune lunette sélectionnée.</p>
    {% endif %}

    <a href="{{ path('app_commande_index') }}">⬅ Retour à la liste</a>
{% endblock %}
