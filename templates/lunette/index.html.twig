{% extends 'base.html.twig' %}

{% block title %}Lunette index{% endblock %}

{% block body %}
    <h1>Lunette index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Serie</th>
                <th>Quantite</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for lunette in lunettes %}
            <tr>
                <td>{{ lunette.id }}</td>
                <td>{{ lunette.serie }}</td>
                <td>{{ lunette.quantite }}</td>
                <td>
                    <a href="{{ path('app_lunette_show', {'id': lunette.id}) }}">show</a>
                    <a href="{{ path('app_lunette_edit', {'id': lunette.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_lunette_new') }}">Create new</a>
{% endblock %}
